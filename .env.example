# AI Provider (claude or openai)
AI_PROVIDER=claude

# Anthropic (Claude)
ANTHROPIC_API_KEY=sk-ant-...

# OpenAI
OPENAI_API_KEY=sk-...

# Polymarket - EOA wallet private key (Polygon network)
POLYMARKET_PRIVATE_KEY=0x...

# Polymarket - your Polymarket profile address (funder address)
# Found at polymarket.com/profile
POLYMARKET_FUNDER_ADDRESS=0x...

# Polymarket API credentials (auto-generated on first run)
# Leave blank — bot will generate these automatically
POLYMARKET_API_KEY=
POLYMARKET_SECRET=
POLYMARKET_PASSPHRASE=

# Safety limits
MAX_ORDER_SIZE_USDC=50
MAX_POSITION_SIZE_USDC=200
DAILY_LOSS_LIMIT_USDC=100
